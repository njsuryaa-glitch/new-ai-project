# Environment Variables for AI Knowledge Assistant API
# Copy this file to .env and populate the values before running.

# ============================================================
# Required: Gemini API Key
# ============================================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# Required: API Authentication Key
# (Secret key clients must pass as X-API-Key header)
# ============================================================
API_KEY=your_strong_api_key_here

# ============================================================
# Database Settings (PostgreSQL)
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=rag_db

# For local development (override if using external DB)
DATABASE_URL=postgresql+asyncpg://postgres:postgrespassword@postgres:5432/rag_db

# ============================================================
# Redis Settings (optional but recommended for production)
# ============================================================
REDIS_URL=redis://redis:6379/0
ENABLE_REDIS=false

# ============================================================
# Document Processing Settings
# ============================================================
MAX_FILE_SIZE_MB=10
CHUNK_SIZE=500
CHUNK_OVERLAP=50
